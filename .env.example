# ── Provider Selection ──────────────────────────────────────────
# Which AI provider to automate: chatgpt | zai | gemini
PROVIDER=chatgpt

# ── ChatGPT Session Tokens ─────────────────────────────────────
# From DevTools → Application → Cookies → chatgpt.com
# Copy value of __Secure-next-auth.session-token.0 (starts with eyJ...)
SESSION_TOKEN_0=paste_your_session_token_0_here

# Copy value of __Secure-next-auth.session-token.1
SESSION_TOKEN_1=paste_your_session_token_1_here

# ── Z.ai Session Token ────────────────────────────────────────
# From DevTools → Application → Cookies → z.ai
# Copy the main session/auth cookie value
ZAI_SESSION_COOKIE=paste_your_zai_session_cookie_here

# ── Gemini Session Tokens ──────────────────────────────────────
# From DevTools → Application → Cookies → gemini.google.com
# Copy value of __Secure-1PSID
GEMINI_PSID=paste_your_gemini_psid_here
# Copy value of __Secure-1PSIDTS
GEMINI_PSIDTS=paste_your_gemini_psidts_here
# Copy value of __Secure-1PSIDCC (optional but recommended)
GEMINI_PSIDCC=paste_your_gemini_psidcc_here

# ── Server Config ──────────────────────────────────────────────
# API port
PORT=3000

# Optional: API key to protect your endpoint (leave blank to disable)
API_KEY=
